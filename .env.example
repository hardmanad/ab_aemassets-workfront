# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it with real credentials.
#
# Obtain these values from the Adobe Developer Console:
# https://developer.adobe.com/console → your App Builder project → workspace credentials

# ─── Adobe I/O Runtime ────────────────────────────────────────────────────────

# Runtime auth token.
# Format: <client-id>:<client-secret>
# Found under Project → Workspace → Runtime → Credentials
AIO_runtime_auth=

# Runtime namespace assigned to your workspace.
# Format: <org-id>-<project-name>  (e.g. 27200-myproject)
AIO_runtime_namespace=

# Adobe I/O Runtime API host. The default is correct for most deployments.
AIO_runtime_apihost=https://adobeioruntime.net

# ─── OAuth Server-to-Server Credential ───────────────────────────────────────

# The client_id of your OAuth Server-to-Server credential.
# Found under Project → Workspace → Credentials → OAuth Server-to-Server → Client ID
SERVICE_API_KEY=
